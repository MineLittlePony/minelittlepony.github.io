{
  "extends": "@total-typescript/tsconfig/bundler/dom/app",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "noUncheckedSideEffectImports": false,
    "paths": {
      "~/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "./src",
    "./*.{ts,js,cjs,mjs}"
  ]
}
